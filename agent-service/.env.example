# Agent Service (Contract A server, port 8001)

# Service token the backend must present (Contract A auth). Must match the backend's AGENT_SERVICE_TOKEN.
AGENT_SERVICE_TOKEN=replace-with-agent-service-token

# Token + base URL to call the backend's Contract B (/internal/*). BACKEND_TOOL_TOKEN must match the
# backend's BACKEND_TOOL_TOKEN.
BACKEND_BASE_URL=http://localhost:8000
BACKEND_TOOL_TOKEN=replace-with-backend-tool-token

# GigaChat for the Final agent runtime. Same vars as agent/.env.
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2-Max

HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO
BACKEND_CONNECT_TIMEOUT_SECONDS=5
BACKEND_READ_TIMEOUT_SECONDS=30
