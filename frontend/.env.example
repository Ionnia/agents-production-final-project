# Frontend environment (Vite). Copy to .env.local and adjust as needed.

# Base URL for the backend API. Defaults to the same-origin "/api/v1" when unset.
# To run the dev server against the real backend (see VITE_USE_MOCKS below):
#   VITE_API_BASE=http://localhost:8000/api/v1
VITE_API_BASE=http://localhost:8000/api/v1

# MSW mock backend toggle.
#   unset / "true"  -> mocks ON in dev (default developer experience, no backend needed)
#   "false"         -> mocks OFF even in dev, so requests hit VITE_API_BASE (the real backend)
# In a production build (`vite build`) mocks are always OFF regardless of this value.
VITE_USE_MOCKS=false
