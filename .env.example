# Environment for `docker compose` (copy to .env and fill in).
# .env is gitignored — never commit real secrets.

# --- GigaChat (the agent's only LLM) ---
# The base64 "Authorization key" for scope GIGACHAT_API_PERS.
GIGACHAT_CREDENTIALS=replace-with-gigachat-authorization-key
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2-Max

# --- Shared service tokens (must be identical for backend and agent-service) ---
# Contract A: token the backend presents to the agent service.
AGENT_SERVICE_TOKEN=replace-with-a-long-random-token
# Contract B: token the agent service presents to the backend's /internal API.
BACKEND_TOOL_TOKEN=replace-with-a-long-random-token

# --- Backend ---
# Secret used to sign user access/refresh JWTs.
JWT_SECRET=replace-with-a-long-random-secret
