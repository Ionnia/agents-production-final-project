DATABASE_URL=sqlite+aiosqlite:///./backend.db
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
BACKEND_TOOL_TOKEN=replace-with-backend-tool-token
AGENT_SERVICE_URL=http://localhost:8001
AGENT_SERVICE_TOKEN=replace-with-agent-service-token
DEFAULT_LOCALE=ru-RU
SUPPORTED_LOCALES=ru-RU,en-US
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
AGENT_CONNECT_TIMEOUT_SECONDS=5
AGENT_READ_TIMEOUT_SECONDS=120
STREAM_TICKET_TTL_SECONDS=60
STREAM_RECONNECT_LEASE_SECONDS=300
